{
  "name": "plumbnepal/backend",
  "description": "PlumbNepal backend for on-demand plumbing in Nepal",
  "license": "proprietary",
  "type": "project",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^13.0",
    "laravel/sanctum": "^4.0",
    "laravel/ai": "^0.5",
    "laravel/tinker": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-root-package-install": ["@php -r \"file_exists('.env') || copy('.env.example', '.env');\""] ,
    "test": "phpunit",
    "test:unit": "phpunit --testsuite Unit"
  }
}
